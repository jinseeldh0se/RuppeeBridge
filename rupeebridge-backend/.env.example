# ── Solana ──────────────────────────────────────────────
# 'devnet' for testing | 'mainnet-beta' for production
SOLANA_NETWORK=devnet

# Your platform master wallet secret key (JSON array of 64 numbers)
# Generate one by running: node scripts/generate-wallet.js
PLATFORM_SECRET_KEY=[]

# ── FX Rates (live) ─────────────────────────────────────
# Get free key at https://fixer.io
FIXER_API_KEY=

# ── INR Payouts ─────────────────────────────────────────
# Get from https://razorpay.com/x
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=

# ── Server ───────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
